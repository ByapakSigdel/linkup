# ============================================
# LinkUp Environment Variables
# ============================================
# Copy this file to .env and fill in values

# ---- Database ----
DATABASE_URL=postgresql://linkup:linkup_dev@localhost:5433/linkup
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=linkup
DATABASE_USER=linkup
DATABASE_PASSWORD=linkup_dev

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JWT Auth ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---- API Server ----
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ---- Web App ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=LinkUp

# ---- Object Storage (S3-compatible) ----
S3_BUCKET=linkup-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=http://localhost:9000

# ---- Email (SMTP) ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@linkup.app
