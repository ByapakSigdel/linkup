# ─── LinkUp API — production env ────────────────────────────────────────────
# Copy to `.env.production` on the server, fill in, and keep it SECRET (never commit).
#   cp .env.production.example .env.production && nano .env.production
# Then:
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

# Postgres (used by the postgres container AND the API's connection string)
POSTGRES_DB=linkup
POSTGRES_USER=linkup
# REQUIRED — pick a strong value:  openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Auth — REQUIRED. Generate:  openssl rand -hex 48
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
# Long-lived, rotating refresh tokens — keeps users signed in for ~6 months.
JWT_REFRESH_EXPIRES_IN=180d

# API
NODE_ENV=production
API_PORT=4000
# Public base URL clients use. For HTTP-on-IP: http://YOUR_VM_IP:4000
# For a domain behind Caddy (tls profile): https://api.yourdomain.com
API_URL=http://YOUR_VM_IP:4000
# CORS — the WEB app's origin (the mobile app uses Bearer tokens, unaffected by CORS).
# Set to your web origin, or "*" if you don't serve the browser app.
CORS_ORIGIN=*

# Domain — only needed for the `tls` (Caddy/HTTPS) profile; must have a DNS A
# record pointing at the VM's external IP.
DOMAIN=api.yourdomain.com

# Google sign-in (REQUIRED to enable "Continue with Google"; leave blank to
# disable — the server fails CLOSED, rejecting all Google sign-ins when unset).
# Use the WEB OAuth client ID: both web AND mobile send an ID token whose
# audience is the web client. Comma-separate GOOGLE_CLIENT_IDS for extra clients.
GOOGLE_CLIENT_ID=

# Email (optional — leave blank to disable verification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@linkup.app

# NOTE: DATABASE_URL and REDIS_URL are set automatically by docker-compose.prod.yml
# (to the internal postgres/redis services) — do not set them here.
